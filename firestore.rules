rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }

    function hasUserDoc(companyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }

    function userCompanyMatches(companyId) {
      return userDoc(companyId).data.companyId == companyId
        || userDoc(companyId).data.companyid == companyId
        || userDoc(companyId).data.uid == request.auth.uid;
    }

    function requestCompanyMatches(companyId) {
      return request.resource.data.companyId == companyId
        || request.resource.data.companyid == companyId;
    }

    function belongsToCompany(companyId) {
      return hasUserDoc(companyId)
        && userCompanyMatches(companyId)
        && userDoc(companyId).data.active != false
        && userDoc(companyId).data.active != 'false';
    }

    function role(companyId) {
      return userDoc(companyId).data.role;
    }

    function hasRole(companyId, roles) {
      return belongsToCompany(companyId) && role(companyId) in roles;
    }

    function isSuperAdmin(companyId) {
      return hasRole(companyId, ['superadmin']);
    }

    function isCompanyAdmin(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa']);
    }

    function canReadCompany(companyId) {
      return belongsToCompany(companyId);
    }

    function canManageWorkOrders(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor']);
    }

    function canManageRequests(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa']);
    }

    function canApproveRequests(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor']);
    }

    function canCreateRequests(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'operaciones', 'operador']);
    }

    function canReviewRequests(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor', 'operaciones']);
    }

    function canImportMaintenance(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa']);
    }

    function canCreateChecklists(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor', 'operaciones', 'mecanico', 'operador']);
    }

    function canReadOperationalInspections(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor', 'operaciones']);
    }

    function canReadNotifications(companyId) {
      return hasRole(companyId, ['superadmin', 'admin_empresa', 'supervisor', 'operaciones']);
    }

    function canWriteCounter(companyId) {
      return belongsToCompany(companyId)
        && (
          isCompanyAdmin(companyId)
          || (request.resource.data.prefix == 'SOL' && role(companyId) in ['operaciones', 'mecanico', 'operador', 'supervisor'])
          || (request.resource.data.prefix == 'CHK' && role(companyId) in ['operaciones', 'mecanico', 'operador', 'supervisor'])
          || (request.resource.data.prefix in ['OT', 'PM'] && role(companyId) in ['supervisor', 'operaciones'])
        );
    }

    match /companies/{companyId} {
      allow read: if canReadCompany(companyId);
      allow create, update, delete: if isSuperAdmin(companyId);

      match /users/{userId} {
        allow read: if signedIn()
          && (userId == request.auth.uid || resource.data.uid == request.auth.uid);
        allow read: if canReadCompany(companyId) && isCompanyAdmin(companyId);
        allow create, update, delete: if isCompanyAdmin(companyId)
          && requestCompanyMatches(companyId)
          && request.resource.data.uid == userId;
      }

      match /equipment/{equipmentId} {
        allow read: if canReadCompany(companyId);
        allow create: if isCompanyAdmin(companyId) || canImportMaintenance(companyId);
        allow update: if isCompanyAdmin(companyId)
          || (canCreateChecklists(companyId)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly(['hourmeter', 'horometroActual', 'lastHourmeterUpdateAt', 'lastHourmeterSource', 'lastChecklistId', 'status', 'updatedAt'])
              && request.resource.data.lastHourmeterSource == 'checklist');
        allow delete: if isCompanyAdmin(companyId);
      }

      match /workOrders/{workOrderId} {
        allow read: if canReadCompany(companyId);
        allow create: if canManageWorkOrders(companyId) || hasRole(companyId, ['operaciones']);
        allow delete: if isCompanyAdmin(companyId);
        allow update: if canManageWorkOrders(companyId)
          || (hasRole(companyId, ['mecanico'])
              && resource.data.assignedTo == request.auth.uid
              && request.resource.data.assignedTo == resource.data.assignedTo);
      }

      match /requests/{requestId} {
        allow read: if canReadCompany(companyId);
        allow create: if (
            canCreateRequests(companyId)
            && request.resource.data.status == 'pendiente'
            && request.resource.data.requestedById == request.auth.uid
          ) || (
            canCreateChecklists(companyId)
            && request.resource.data.status == 'pendiente_operaciones'
            && request.resource.data.source == 'checklist'
            && request.resource.data.requestedById == request.auth.uid
          ) || (
            canReviewRequests(companyId)
            && request.resource.data.status == 'pendiente_revision_mantenimiento'
            && request.resource.data.source == 'finding'
            && request.resource.data.sourceFindingId is string
          );
        allow update: if canManageRequests(companyId) || canApproveRequests(companyId) || canReviewRequests(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /checklists/{checklistId} {
        allow read: if canReadOperationalInspections(companyId)
          || (hasRole(companyId, ['operador']) && resource.data.operatorId == request.auth.uid)
          || (hasRole(companyId, ['mecanico']) && resource.data.workOrderId is string);
        allow create: if canCreateChecklists(companyId)
          && request.resource.data.operatorId == request.auth.uid;
        allow update: if isCompanyAdmin(companyId) || hasRole(companyId, ['supervisor']);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /findings/{findingId} {
        allow read: if canReadOperationalInspections(companyId)
          || (hasRole(companyId, ['operador']) && resource.data.operatorId == request.auth.uid)
          || (hasRole(companyId, ['mecanico']) && resource.data.workOrderId is string);
        allow create: if canCreateChecklists(companyId)
          && request.resource.data.operatorId == request.auth.uid
          && request.resource.data.status == 'pendiente_revision_operaciones'
          && (
            request.resource.data.source == 'manual_operator_report'
            || (request.resource.data.source == 'checklist' && request.resource.data.sourceChecklistId is string)
          );
        allow update: if canReviewRequests(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /notifications/{notificationId} {
        allow read: if canReadNotifications(companyId);
        allow create: if belongsToCompany(companyId)
          && request.resource.data.type == 'checklist_finding'
          && request.resource.data.checklistId is string
          && request.resource.data.operatorId == request.auth.uid;
        allow update: if canReadNotifications(companyId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'readAt', 'readBy', 'updatedAt']);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /maintenancePlans/{planId} {
        allow read: if canReadCompany(companyId);
        allow create, update: if isCompanyAdmin(companyId) || canImportMaintenance(companyId) || canCreateChecklists(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /maintenanceHistory/{historyId} {
        allow read: if canReadCompany(companyId);
        allow create, update: if canImportMaintenance(companyId) || canManageWorkOrders(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /imports/{importId} {
        allow read: if isCompanyAdmin(companyId);
        allow create: if canImportMaintenance(companyId);
        allow update, delete: if isCompanyAdmin(companyId);
      }

      match /spareParts/{partId} {
        allow read: if canReadCompany(companyId);
        allow create, update, delete: if isCompanyAdmin(companyId);
      }

      match /settings/{settingId} {
        allow read: if canReadCompany(companyId);
        allow create, update, delete: if isCompanyAdmin(companyId);
      }

      match /counters/{counterName} {
        allow read: if canReadCompany(companyId);
        allow create, update: if canWriteCounter(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      match /auditLogs/{logId} {
        allow read: if isCompanyAdmin(companyId) || canManageWorkOrders(companyId);
        allow create: if belongsToCompany(companyId);
        allow update, delete: if false;
      }
    }


    // Puente de compatibilidad para la base legacy del ERP original.
    // Mantiene lectura/escritura de documentos tipo mantek_v2/{coleccion} con { data: [] }
    // mientras se migra gradualmente a companies/{companyId}/{collection}/{docId}.
    match /mantek_v2/{legacyDocId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
